# ============================================================
# .env.prod.example — Production Environment Variables
# انسخه لـ .env.prod وعبّيه قبل تشغيل docker-compose.prod.yml
# الاستخدام: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# ===== PostgreSQL =====
POSTGRES_USER=fa_arch_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=fa_arch_db

# ===== Redis =====
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ===== JWT =====
JWT_ACCESS_SECRET=CHANGE_THIS_TO_A_256_BIT_RANDOM_STRING_FOR_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_256_BIT_RANDOM_STRING_FOR_PRODUCTION
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== URLs =====
FRONTEND_URL=https://fa-arch.cu.edu.eg
NEXT_PUBLIC_API_URL=https://fa-arch.cu.edu.eg/api
NEXT_PUBLIC_APP_URL=https://fa-arch.cu.edu.eg
NEXT_PUBLIC_APP_NAME=كلية الآثار — جامعة القاهرة

# ===== Email (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fa-arch.cu.edu.eg

# ===== Files =====
MAX_FILE_SIZE_MB=25

# ===== reCAPTCHA =====
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
