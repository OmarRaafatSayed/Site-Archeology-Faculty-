# ===== Database =====
DATABASE_URL="postgresql://postgres:password@localhost:5432/fa_arch_db"

# ===== Redis =====
REDIS_URL="redis://localhost:6379"

# ===== JWT =====
JWT_ACCESS_SECRET="change_this_to_a_256_bit_random_string"
JWT_REFRESH_SECRET="change_this_to_another_256_bit_random_string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ===== App =====
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ===== Email (SMTP) =====
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@fa-arch.cu.edu.eg"

# ===== File Storage =====
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE_MB=25

# ===== Google reCAPTCHA =====
RECAPTCHA_SECRET_KEY=""

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
